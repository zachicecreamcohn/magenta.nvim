{
  "sandbox": {
    "network": {
      "allowUnixSockets": ["/private/tmp", "/tmp/claude"],
      "allowAllUnixSockets": true,
      "allowedDomains": ["mcp.slack.com"]
    },
    "filesystem": {
      "allowRead": [
        "./.github",
        "./.magenta",
        "./.vscode",
        "./test-plugins/nvim-cmp/.githooks",
        "./test-plugins/nvim-cmp/.github",
        "./node/packages/sandbox-runtime/.github",
        "./node/packages/sandbox-runtime/.vscode",
        "~/.config/slack-skill"
      ],
      "allowWrite": [
        "/private/tmp/magenta/",
        "/tmp/claude"
      ]
    }
  }
}
