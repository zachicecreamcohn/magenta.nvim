{
  "container": {
    "dockerfile": "docker/Dockerfile",
    "workspacePath": "/workspace"
  },
  "sandbox": {
    "network": {
      "allowUnixSockets": ["/private/tmp"]
    },
    "filesystem": {
      "allowRead": [
        "./.github",
        "./.magenta",
        "./.vscode",
        "./test-plugins/nvim-cmp/.githooks",
        "./test-plugins/nvim-cmp/.github",
        "./node/packages/sandbox-runtime/.github",
        "./node/packages/sandbox-runtime/.vscode"
      ],
      "allowWrite": [
        "/private/tmp/magenta/"
      ]
    }
  }
}
